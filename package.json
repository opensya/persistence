{
  "name": "@opensya/persistence",
  "version": "0.2.1",
  "description": "The persistence engine behind OpenSya.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": {
    "name": "domutala"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opensya/persistence.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "peerDependencies": {
    "drizzle-orm": "1.0.0-beta.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "pg": "^8.22.0",
    "tsdown": "^0.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  },
  "packageManager": "pnpm@11.10.0",
  "keywords": [
    "opensya",
    "persistence",
    "database",
    "orm",
    "drizzle",
    "typescript",
    "metadata",
    "query-engine",
    "adapter",
